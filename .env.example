# =============================================================================
# Personal Jira MVP — 환경변수 템플릿
# =============================================================================
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   cp .env.example .env
#
# 주의: .env 파일은 .gitignore에 포함되어 있으므로 커밋되지 않습니다.
#       실제 비밀번호나 시크릿을 이 파일(.env.example)에 넣지 마세요.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL 데이터베이스
# -----------------------------------------------------------------------------

# SQLAlchemy 연결 문자열 (asyncpg 드라이버 사용)
# 형식: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# 로컬 개발: localhost:5433 (docker-compose에서 5433→5432 포트 매핑)
# Docker 내부: postgres:5432 (서비스명으로 접근)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/personal_jira

# PostgreSQL 컨테이너 설정 (docker-compose.yml에서 사용)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=personal_jira

# -----------------------------------------------------------------------------
# 백엔드 (FastAPI)
# -----------------------------------------------------------------------------

# FastAPI 서버 포트 (기본값: 8000)
BACKEND_PORT=8000

# 애플리케이션 환경: development | staging | production
APP_ENV=development

# JWT/세션 서명용 시크릿 키
# 프로덕션에서는 반드시 강력한 랜덤 값으로 교체하세요:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# 프론트엔드 (Vite + React)
# -----------------------------------------------------------------------------

# Vite 개발 서버 포트 (기본값: 5173)
FRONTEND_PORT=5173
